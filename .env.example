# GigaChat: ключ авторизации из личного кабинета (Base64 от client_id:client_secret)
# https://developers.sber.ru/docs/ru/gigachat/api/overview
GIGACHAT_AUTHORIZATION_KEY=

# Опционально: путь к PEM (Russian Trusted Root). Если не задан — ищется russian_trusted_root_ca.pem в корне репозитория.
# GIGACHAT_CA_BUNDLE=

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
# ID чата (число, например из @userinfobot или getUpdates)
TELEGRAM_CHAT_ID=

# Порт API (опционально)
PORT=8787
